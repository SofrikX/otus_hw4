rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    function isAuthor(authorId) {
      return signedIn() && request.auth.uid == authorId;
    }

    function existingPost(postId) {
      return get(/databases/$(database)/documents/posts/$(postId));
    }

    function immutableField(field) {
      return !(field in resource.data) ||
        request.resource.data[field] == resource.data[field];
    }

    function postCountersAreImmutable() {
      return immutableField('likesCount') &&
        immutableField('commentsCount');
    }

    function createsOwnDocument(userId) {
      return request.resource.data.id == userId;
    }

    function isValidComment(postId) {
      return request.resource.data.postId == postId &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 500;
    }

    function isWalkCreator() {
      return isOwner(resource.data.creatorId);
    }

    function keepsWalkOwner() {
      return request.resource.data.creatorId == resource.data.creatorId;
    }

    function isWalkJoin() {
      return signedIn() &&
        keepsWalkOwner() &&
        resource.data.status == 'active' &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['participantIds', 'participantsCount', 'updatedAt']) &&
        !(request.auth.uid in resource.data.participantIds) &&
        request.auth.uid in request.resource.data.participantIds &&
        request.resource.data.participantIds.size() ==
          resource.data.participantIds.size() + 1 &&
        request.resource.data.participantsCount ==
          resource.data.participantsCount + 1;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && createsOwnDocument(userId);
      allow update: if isOwner(userId) && createsOwnDocument(userId);
      allow delete: if isOwner(userId);
    }

    match /pets/{petId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        isOwner(request.resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId) &&
        request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner(resource.data.ownerId);
    }

    match /posts/{postId} {
      allow read: if signedIn() &&
        (!('deletedAt' in resource.data) || resource.data.deletedAt == null);
      allow create: if signedIn() &&
        isAuthor(request.resource.data.authorId) &&
        request.resource.data.likesCount == 0 &&
        request.resource.data.commentsCount == 0;
      allow update: if isAuthor(resource.data.authorId) &&
        request.resource.data.authorId == resource.data.authorId &&
        postCountersAreImmutable();
      allow delete: if isAuthor(resource.data.authorId);

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && isValidComment(postId);
        allow update: if isAuthor(resource.data.authorId) &&
          request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.postId == resource.data.postId;
        allow delete: if isAuthor(resource.data.authorId) ||
          isAuthor(existingPost(postId).data.authorId);
      }

      match /likes/{userId} {
        allow read: if signedIn();
        allow create: if isOwner(userId) &&
          request.resource.data.userId == userId &&
          request.resource.data.postId == postId;
        allow delete: if isOwner(userId);
        allow update: if false;
      }
    }

    match /walks/{walkId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        isOwner(request.resource.data.creatorId) &&
        request.auth.uid in request.resource.data.participantIds &&
        request.resource.data.participantsCount >= 1;
      allow update: if isWalkCreator() && keepsWalkOwner() ||
        isWalkJoin();
      allow delete: if isWalkCreator();
    }

    match /chats/{chatId} {
      function chatDocument() {
        return get(/databases/$(database)/documents/chats/$(chatId));
      }

      function isChatParticipant() {
        return signedIn() &&
          request.auth.uid in chatDocument().data.participantIds;
      }

      function isNewChatParticipant() {
        return signedIn() &&
          request.auth.uid in request.resource.data.participantIds;
      }

      function keepsChatParticipants() {
        return request.resource.data.participantIds ==
          resource.data.participantIds;
      }

      allow read: if isChatParticipant();
      allow create: if isNewChatParticipant();
      allow update: if isChatParticipant() && keepsChatParticipants();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant();
        allow create: if isChatParticipant() &&
          request.resource.data.chatId == chatId &&
          isAuthor(request.resource.data.senderId) &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 2000;
        allow update, delete: if false;
      }
    }
  }
}
