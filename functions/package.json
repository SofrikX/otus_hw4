{
  "name": "petconnect-functions",
  "description": "Cloud Functions HTTP API for PetConnect HW5.",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test lib/test/*.test.js",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth,storage",
    "seed": "node ../scripts/seed_firestore.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^6.1.2"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "typescript": "^5.7.2"
  }
}
